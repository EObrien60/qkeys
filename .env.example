# --- Database ---------------------------------------------------------------
# Postgres connection string for the SaaS database that owns the platform.* tables.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/qkeys_dev

# --- Secret pepper (REQUIRED) -----------------------------------------------
# Server-side pepper for the keyed hash of key secrets. MUST be a long random
# string in production and kept OUT of the database. Rotating it invalidates all
# existing keys. The client refuses to start without it.
API_KEYS_PEPPER=change-me-to-a-long-random-secret

# --- keysd (optional expiry sweeper) ----------------------------------------
KEYSD_INSTANCE_ID=keysd-local-1

# How often to sweep for expired keys, in milliseconds (default 60000)
KEYSD_SWEEP_INTERVAL_MS=60000

# Keys marked expired per batch (default 500)
KEYSD_BATCH_SIZE=500

# debug | info | warn | error (default info)
KEYSD_LOG_LEVEL=info

# Optional: expose GET /healthz and GET /readyz on this port. Omit to disable.
KEYSD_HEALTH_PORT=8084

# Apply migrations on boot (dev convenience).
KEYSD_MIGRATE_ON_BOOT=false
