{
  "name": "@obh/keysd",
  "version": "0.1.0",
  "private": true,
  "description": "obh-keysd: optional maintenance worker that sweeps expired API keys.",
  "bin": {
    "obh-keysd": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "migrate": "node dist/migrate.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@obh/api-keys": "workspace:*",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
